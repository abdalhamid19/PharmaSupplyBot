# ── Default API Config ──

# ── Fallback Models (tried in order when API fails) ──
AI_MODEL=minimax-m2.5-free
FALLBACK_MODELS=nemotron-3-super-free,hy3-preview-free,trinity-large-preview-free

# ── Review Model (second AI to cross-verify low-confidence decisions) ──
REVIEW_MODEL=big-pickle

# ── Review confidence threshold ──
AI_REVIEW_THRESHOLD=0.95

